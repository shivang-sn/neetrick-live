# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored; NEVER put real secrets in THIS example file
# (this .example file IS committed to the repo).
#
# Contact form (/api/contact). Pick ONE sender.

# --- Option A: Resend API (recommended, https://resend.com) ---
RESEND_API_KEY=re_your_key_here
RESEND_FROM=Neetrick <onboarding@resend.dev>
CONTACT_TO=sales@neetrick.com

# --- Option B: Gmail SMTP ---
# SMTP_PASS must be a Gmail App Password (16 chars, no spaces) - enable
# 2-Step Verification then: https://myaccount.google.com/apppasswords
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=your-gmail@gmail.com
# SMTP_PASS=your-16-char-app-password
# CONTACT_TO=sales@neetrick.com

# --- Option C: GoDaddy Titan SMTP ---
# SMTP_HOST=smtp.titan.email
# SMTP_PORT=465
# SMTP_USER=sales@neetrick.com
# SMTP_PASS=your-mailbox-password
# CONTACT_TO=sales@neetrick.com

# Admin dashboard (/admin/visitors) - required, there is no default password.
ADMIN_PASSWORD=choose-a-real-password
# Signs the admin session cookie. Any long random string.
ADMIN_SESSION_SECRET=choose-a-long-random-string
