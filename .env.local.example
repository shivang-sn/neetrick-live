# Copy this file to .env.local and fill in the real password.
# GoDaddy Titan email SMTP (mailbox: sales@neetrick.com)
SMTP_HOST=smtp.titan.email
SMTP_PORT=465
SMTP_USER=sales@neetrick.com
SMTP_PASS=your-mailbox-password
CONTACT_TO=sales@neetrick.com

# Optional fallback if Titan SMTP won't authenticate (https://resend.com)
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM=Neetrick <onboarding@resend.dev>
